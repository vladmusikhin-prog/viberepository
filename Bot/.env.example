BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
ENV=development
LOG_LEVEL=INFO
WHALE_THRESHOLD_USD=100000
# Lower whale threshold for Crypto (Politics/Sports/Geopolitics use WHALE_THRESHOLD_USD)
WHALE_THRESHOLD_CRYPTO=20000
# Macro markets (Fed, CPI, GDP, etc.)
WHALE_THRESHOLD_ECONOMICS=75000
SIGNAL_POLL_INTERVAL_SEC=30
# Max trade price for alerting (0.00 and values above this are filtered out)
ALERT_MAX_PRICE=0.95
# Crypto markets often trade near 0.99; separate (higher) cap for Crypto category
ALERT_MAX_PRICE_CRYPTO=0.999

# polymarket = background worker polls Data API | demo = no background worker (only manual test button)
SIGNAL_SOURCE=polymarket
POLYMARKET_DATA_API_BASE=https://data-api.polymarket.com
POLYMARKET_TRADES_LIMIT=100
# Ignore trades older than this many seconds (avoids spam after restart)
POLYMARKET_MAX_TRADE_AGE_SEC=600

# Startup backfill: fetch older (missed) trades once on bot start
POLYMARKET_BACKFILL_ENABLED=true
POLYMARKET_BACKFILL_AGE_SEC=86400
POLYMARKET_BACKFILL_LIMIT=200
POLYMARKET_BACKFILL_MAX_PAGES=8

# Resolution follow-up alerts (second notification when market closes)
POLYMARKET_RESOLUTION_ENABLED=true
POLYMARKET_RESOLUTION_POLL_INTERVAL_SEC=120
POLYMARKET_RESOLUTION_BATCH_SIZE=25
POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com

# Trader profile in whale alerts (WR + realized P&L from closed positions)
TRADER_STATS_ENABLED=true
TRADER_STATS_POSITIONS_LIMIT=100
TRADER_STATS_CACHE_TTL_SEC=3600

# Admin telegram user ids (comma-separated) allowed to run /admin_stats
ADMIN_USER_IDS=

# Interaction analytics: session reports posted to a Telegram group (Sonar Whale Logs)
ANALYTICS_ENABLED=true
ANALYTICS_CHAT_ID=-1003979556527
ANALYTICS_SESSION_TIMEOUT_SEC=180

# Persistence mode: memory (MVP, state resets on restart) | sqlite (state survives restarts)
PERSISTENCE_MODE=sqlite
# SQLite DB path (relative to Bot/ directory is OK)
SQLITE_DB_PATH=./data/bot.sqlite3
